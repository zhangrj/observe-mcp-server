# Example .env for observe-mcp-server
# Copy to `.env` and edit values for your environment.

# Prometheus connection (PrometheusSettings: env prefix PROMETHEUS_)
# Use a reachable Prometheus HTTP API endpoint
PROMETHEUS_URL="http://prometheus.example:9090"
# Optional auth
PROMETHEUS_TOKEN=""
PROMETHEUS_USERNAME=""
PROMETHEUS_PASSWORD=""

# Optional: path to alias mapping JSON (relative to repo root)
PROMETHEUS_ALIAS_PATH="config/prometheus_aliases.json"

# Optional cache TTL overrides (seconds)
PROMETHEUS_CATALOG_TTL_SECONDS=600
PROMETHEUS_SCHEMA_TTL_SECONDS=600
PROMETHEUS_LABEL_PREVIEW_TTL_SECONDS=180
PROMETHEUS_ALIAS_TTL_SECONDS=1800
# -----------------------------
# MCP runtime
# -----------------------------
OBSERVE_LOG_LEVEL=INFO
OBSERVE_MCP_TRANSPORT=stdio         # stdio | sse | streamable-http
OBSERVE_MCP_BIND_HOST=127.0.0.1
OBSERVE_MCP_BIND_PORT=8000
OBSERVE_MCP_PATH=/mcp

# Enable toolsets (Phase-1 only OpenObserve enabled)
OBSERVE_ENABLE_OPENOBSERVE=true
OBSERVE_ENABLE_PROMETHEUS=true
OBSERVE_ENABLE_SKYWALKING=true

# Optional: add a prefix for ALL tool names (useful for multi-env)
OBSERVE_TOOL_PREFIX=

# -----------------------------
# OpenObserve (required for Phase-1)
# -----------------------------
OPENOBSERVE_BASE_URL=http://localhost:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_USERNAME=admin@admin.com
OPENOBSERVE_PASSWORD=admin
OPENOBSERVE_VERIFY_SSL=true
OPENOBSERVE_TIMEOUT_SECONDS=30 # optional, default 30s
OPENOBSERVE_MAX_PAGE_SIZE=500 # optional, default 500
OPENOBSERVE_STREAM_CATALOG_PATH=/tmp/openobserve_stream_catalog.json # optional, used for describe streams

# -----------------------------
# SkyWalking (GraphQL)
# -----------------------------
# Example: http://localhost:12800/graphql
SKYWALKING_BASE_URL="http://localhost:12800/graphql"
SKYWALKING_TOKEN=""
SKYWALKING_TIMEOUT_SECONDS=30